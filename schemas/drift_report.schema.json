{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Cogitator Drift Report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "drifted", "issues"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "drifted": { "type": "boolean" },
    "issues": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "expected", "actual"],
            "properties": {
              "kind": { "const": "tool_call_count_mismatch" },
              "expected": { "type": "integer", "minimum": 0 },
              "actual": { "type": "integer", "minimum": 0 }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "index", "expected", "actual"],
            "properties": {
              "kind": { "const": "tool_step_mismatch" },
              "index": { "type": "integer", "minimum": 0 },
              "expected": { "type": "integer", "minimum": 0 },
              "actual": { "type": "integer", "minimum": 0 }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "index"],
            "properties": {
              "kind": { "const": "tool_request_mismatch" },
              "index": { "type": "integer", "minimum": 0 }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "index", "expected", "actual"],
            "properties": {
              "kind": { "const": "tool_call_index_mismatch" },
              "index": { "type": "integer", "minimum": 0 },
              "expected": { "type": "integer", "minimum": 0 },
              "actual": { "type": "integer", "minimum": 0 }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "index"],
            "properties": {
              "kind": { "const": "tool_fault_mismatch" },
              "index": { "type": "integer", "minimum": 0 }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "index"],
            "properties": {
              "kind": { "const": "tool_response_hash_mismatch" },
              "index": { "type": "integer", "minimum": 0 }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "index"],
            "properties": {
              "kind": { "const": "unexpected_tool_request" },
              "index": { "type": "integer", "minimum": 0 }
            }
          }
        ]
      }
    },
    "first_mismatch": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "index",
            "expected",
            "observed",
            "expected_response_hash",
            "observed_response_hash"
          ],
          "properties": {
            "index": { "type": "integer", "minimum": 0 },
            "expected": {
              "anyOf": [
                { "type": "null" },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["tool_name", "arguments", "fault"],
                  "properties": {
                    "tool_name": { "type": "string" },
                    "arguments": {},
                    "fault": { "type": ["object", "null"] }
                  }
                }
              ]
            },
            "observed": {
              "anyOf": [
                { "type": "null" },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["tool_name", "arguments", "fault"],
                  "properties": {
                    "tool_name": { "type": "string" },
                    "arguments": {},
                    "fault": { "type": ["object", "null"] }
                  }
                }
              ]
            },
            "expected_response_hash": { "type": ["string", "null"] },
            "observed_response_hash": { "type": ["string", "null"] }
          }
        }
      ]
    }
  }
}
