{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Cogitator Tool Transcript",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "mode", "entries"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "mode": { "type": "string", "enum": ["live", "replay"] },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step", "tool_call_idx", "tool_name", "request", "outcome"],
        "properties": {
          "step": { "type": "integer", "minimum": 0 },
          "tool_call_idx": { "type": "integer", "minimum": 0 },
          "tool_name": { "type": "string" },
          "request": {},
          "outcome": {
            "oneOf": [
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["kind", "output"],
                "properties": {
                  "kind": { "const": "ok" },
                  "output": {},
                  "simulated_latency_ms": { "type": ["integer", "null"], "minimum": 0 }
                }
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["kind", "error"],
                "properties": {
                  "kind": { "const": "err" },
                  "error": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["error_kind"],
                    "properties": {
                      "error_kind": {
                        "type": "string",
                        "enum": ["timeout", "drop", "corrupt", "tool_error"]
                      },
                      "message": { "type": ["string", "null"] }
                    }
                  },
                  "simulated_latency_ms": { "type": ["integer", "null"], "minimum": 0 }
                }
              }
            ]
          },
          "fault": {
            "type": ["object", "null"],
            "oneOf": [
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["kind", "domain"],
                "properties": {
                  "kind": { "const": "timeout" },
                  "domain": { "type": "string" },
                  "timeout_ms": { "type": ["integer", "null"], "minimum": 0 }
                }
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["kind", "domain"],
                "properties": {
                  "kind": { "const": "drop" },
                  "domain": { "type": "string" }
                }
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["kind", "domain", "mask"],
                "properties": {
                  "kind": { "const": "corrupt" },
                  "domain": { "type": "string" },
                  "mask": { "type": "integer" }
                }
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["kind", "domain", "latency_ms"],
                "properties": {
                  "kind": { "const": "latency_sim" },
                  "domain": { "type": "string" },
                  "latency_ms": { "type": "integer", "minimum": 0 }
                }
              }
            ]
          }
        }
      }
    }
  }
}
